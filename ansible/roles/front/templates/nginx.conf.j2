##############################################
# roles/front/templates/nginx.conf.j2
# Template Nginx - reverse proxy
# Variables injectées par Ansible
##############################################

# Redirection HTTP → HTTPS
server {
    listen 80;
    server_name {{ nginx_domain }};

    # Autoriser Certbot pour la vérification ACME
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS
server {
    listen 443 ssl;
    server_name {{ nginx_domain }};

    # Certificats Let's Encrypt (générés par Certbot)
    ssl_certificate     /etc/letsencrypt/live/{{ nginx_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ nginx_domain }}/privkey.pem;

    # Paramètres SSL sécurisés
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    add_header Strict-Transport-Security "max-age=63072000" always;

    # Logs
    access_log /var/log/nginx/{{ nginx_config_name }}-access.log;
    error_log  /var/log/nginx/{{ nginx_config_name }}-error.log;

    # ── Frontend (React) ────────────────────────────────────────────────────
    location / {
        proxy_pass         http://127.0.0.1:{{ front_port }};
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # ── API Backend (Node.js dans sous-réseau privé) ────────────────────────
    location /api/ {
        proxy_pass         http://{{ back_private_ip }}:{{ back_port }}/;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Timeouts pour les requêtes API
        proxy_connect_timeout 60s;
        proxy_read_timeout    60s;
    }
}
