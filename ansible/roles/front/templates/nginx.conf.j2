##############################################
# roles/front/templates/nginx.conf.j2
# Template Nginx - reverse proxy dynamique
# Gère automatiquement HTTP et HTTPS si le certificat existe
##############################################

{% if ssl_cert_stat is defined and ssl_cert_stat.stat.exists %}
# ── Configuration HTTPS active (Certificat existant) ─────────────────────────

server {
    listen 80;
    server_name {{ nginx_domain }};

    # Redirection permanente vers HTTPS
    location / {
        return 301 https://$host$request_uri;
    }

    # Nécessaire pour les renouvellements Certbot
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }
}

server {
    listen 443 ssl;
    server_name {{ nginx_domain }};

    # Certificats SSL Let's Encrypt
    ssl_certificate /etc/letsencrypt/live/{{ nginx_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ nginx_domain }}/privkey.pem;

    # Optimisations SSL standards
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Logs
    access_log /var/log/nginx/{{ nginx_config_name }}-access.log;
    error_log  /var/log/nginx/{{ nginx_config_name }}-error.log;

    # ── Frontend (React) ────────────────────────────────────────────────────
    location / {
        proxy_pass         http://127.0.0.1:{{ front_port }};
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # ── API Backend (Node.js dans sous-réseau privé) ────────────────────────
    location /api/ {
        proxy_pass         http://{{ back_private_ip }}:{{ back_port }}/;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_read_timeout    60s;
    }
}

{% else %}
# ── Configuration Initiale HTTP uniquement (Bootstrap) ──────────────────────

server {
    listen 80;
    server_name {{ nginx_domain }};

    # Autoriser Certbot pour la vérification ACME (challenge HTTP-01)
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    # Logs
    access_log /var/log/nginx/{{ nginx_config_name }}-access.log;
    error_log  /var/log/nginx/{{ nginx_config_name }}-error.log;

    # ── Frontend (React) ────────────────────────────────────────────────────
    location / {
        proxy_pass         http://127.0.0.1:{{ front_port }};
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # ── API Backend (Node.js dans sous-réseau privé) ────────────────────────
    location /api/ {
        proxy_pass         http://{{ back_private_ip }}:{{ back_port }}/;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_read_timeout    60s;
    }
}
{% endif %}
