##############################################
# roles/front/templates/nginx.conf.j2
# Template Nginx - reverse proxy
# PHASE 1 : HTTP uniquement (avant Certbot)
# Certbot va automatiquement ajouter le bloc HTTPS
##############################################

server {
    listen 80;
    server_name {{ nginx_domain }};

    # Autoriser Certbot pour la vérification ACME (challenge HTTP-01)
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    # Logs
    access_log /var/log/nginx/{{ nginx_config_name }}-access.log;
    error_log  /var/log/nginx/{{ nginx_config_name }}-error.log;

    # ── Frontend (React) ────────────────────────────────────────────────────
    location / {
        proxy_pass         http://127.0.0.1:{{ front_port }};
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # ── API Backend (Node.js dans sous-réseau privé) ────────────────────────
    location /api/ {
        proxy_pass         http://{{ back_private_ip }}:{{ back_port }}/;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_read_timeout    60s;
    }
}
