##############################################
# .gitignore - MediShop Todo DevOps Project
##############################################

# ── Terraform ──────────────────────────────────────────────────────
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfvars        # ← CRITIQUE : ne jamais committer !
terraform/terraform.tfvars.local
terraform/crash.log
terraform/override.tf
*.tfplan

# ── Ansible ────────────────────────────────────────────────────────
ansible/inventory/hosts.ini       # ← Généré dynamiquement
ansible/terraform_outputs.json    # ← Contient des IPs
ansible/*.retry
ansible/.vault_pass
*.vault

# ── Secrets & clés SSH ─────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
.env
.env.local
.env.production
.env.*
!.env.example
set_github_secrets.py  # Script d'automatisation temporaire


# ── Node.js ────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
.npm

# ── React build ────────────────────────────────────────────────────
app/frontend/build/

# ── Docker ─────────────────────────────────────────────────────────
.docker/

# ── OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── IDE ────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.iml

# ── Logs ──────────────────────────────────────────────────────────
*.log
logs/
